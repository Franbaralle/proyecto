rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Resultados del BDI: cualquier usuario autenticado puede crear y leer
    match /bdiResultados/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Permisos de reevaluación: cualquier usuario autenticado puede leer y escribir
    match /testReevaluationPermissions/{docId} {
      allow read, write: if request.auth != null;
    }

    // Perfiles de pacientes: lectura pública, escritura libre
    // (el paciente escribe sus propios datos; el psicólogo actualiza testsHabilitados)
    match /pacientes/{uid} {
      allow read: if true;
      allow write: if true;
    }

    // Psicólogos: lectura pública (necesaria para validar código antes de autenticarse)
    // Solo usuarios autenticados pueden escribir
    match /psicologos/{email} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
